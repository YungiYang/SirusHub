local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- Глобальные настройки
_G.HitboxEnabled = false
_G.HitboxSizeValue = 10
_G.HitboxSize = Vector3.new(10, 10, 10)
_G.ESP_Enabled = false
_G.ESP_Color = Color3.fromRGB(255, 0, 0)
_G.Arrows_Enabled = false
_G.Arrow_Radius = 150 

local function applyHitbox(character)
    if not character or character == LocalPlayer.Character or character.Name == LocalPlayer.Name then 
        return 
    end
    
    pcall(function()
        local head = character:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            if _G.HitboxEnabled then
                head.Size = _G.HitboxSize
                head.Transparency = 0.5
                head.CanCollide = false
                head.Massless = true
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                head.Transparency = 0
                head.CanCollide = true
                head.Massless = false
            end
        end
    end)
end

local function createESP(player)
    local box = Drawing.new("Square")
    local Outline = Drawing.new("Square")
    local Dtext = Drawing.new("Text")
    local arrow = Drawing.new("Circle")

    -- Настройка объектов
    box.Visible = false
    box.Thickness = 3
    box.Color = Color3.fromRGB(0, 0, 0) -- Исправлено: Color вместо color
    box.Filled = false

    Outline.Visible = false
    Outline.Thickness = 1
    Outline.Color = _G.ESP_Color
    Outline.Filled = false

    Dtext.Visible = false 
    Dtext.Color = Color3.fromRGB(255, 255, 255)
    Dtext.Size = 16
    Dtext.Center = true
    Dtext.Outline = true

    arrow.Visible = false
    arrow.Radius = 6 
    arrow.Filled = true
    arrow.NumSides = 32

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player or not player.Parent then
            pcall(function() 
                box:Remove(); Outline:Remove(); Dtext:Remove(); arrow:Remove() 
            end)
            connection:Disconnect()
            return
        end

        pcall(function()
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local RootPart = char.HumanoidRootPart
                local RootPos, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)

                if _G.ESP_Enabled and OnScreen then
                    local head = char:FindFirstChild("Head")
                    if head then
                        local HeadPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                        local LegPos = Camera:WorldToViewportPoint(RootPart.Position - Vector3.new(0, 3, 0))
                        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude
                        
                        local sizeX = 2000 / RootPos.Z
                        local sizeY = HeadPos.Y - LegPos.Y
                        local posX = RootPos.X - sizeX / 2
                        local posY = RootPos.Y - sizeY / 2

                        -- Внешняя черная обводка
                        box.Visible = true
                        box.Size = Vector2.new(sizeX, sizeY)
                        box.Position = Vector2.new(posX, posY)

                        -- Внутренняя цветная линия
                        Outline.Visible = true
                        Outline.Size = Vector2.new(sizeX, sizeY)
                        Outline.Position = Vector2.new(posX, posY)
                        Outline.Color = _G.ESP_Color

                        Dtext.Visible = true
                        Dtext.Text = "[" .. math.floor(dist) .. " studs]"
                        Dtext.Position = Vector2.new(RootPos.X, posY + sizeY + 2)
                    end
                else
                    box.Visible = false; Outline.Visible = false; Dtext.Visible = false
                end

                if _G.Arrows_Enabled then
                    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local RelativePos = Camera.CFrame:PointToObjectSpace(RootPart.Position)
                    local Angle = math.atan2(-RelativePos.X, -RelativePos.Z)
                    local Direction = Vector2.new(math.sin(Angle), math.cos(Angle))
                    
                    arrow.Position = ScreenCenter + (Direction * _G.Arrow_Radius)
                    arrow.Color = _G.ESP_Color
                    arrow.Visible = not OnScreen 
                else
                    arrow.Visible = false
                end
            else
                box.Visible = false; Outline.Visible = false; Dtext.Visible = false; arrow.Visible = false
            end
        end)
    end)
end

-- Инициализация
local function onPlayerAdded(player)
    if player ~= LocalPlayer then
        createESP(player)
        player.CharacterAdded:Connect(function(character)
            task.wait(0.5)
            applyHitbox(character)
        end)
        if player.Character then applyHitbox(player.Character) end
    end
end

for _, player in pairs(Players:GetPlayers()) do onPlayerAdded(player) end
Players.PlayerAdded:Connect(onPlayerAdded)

